# ============================================================
# AegisHarness — Environment Configuration
# ============================================================
# 1. Copy this file:  cp .env.example .env
# 2. Fill in the values below (never commit .env to git)
# 3. Restart the backend after editing: npm run backend
# ============================================================


# ── AI Providers ─────────────────────────────────────────────
# Gemini is the PRIMARY provider for Phase 1 prompt expansion
# and Phase 2 bug-list generation.
# Get your key at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta

# Recommended model. Options:
#   gemini-2.5-flash-lite  (fast, free tier: 20 req/min)
#   gemini-2.0-flash       (higher free-tier limits, recommended)
#   gemini-2.5-pro         (best quality, lower rate limits)
GEMINI_MODEL=gemini-2.0-flash

# Clod.io is the FALLBACK AI provider (used if Gemini is unavailable).
# Also used for Phase 4 code generation.
# Get your key at: https://clod.io
CLOD_API_KEY=your_clod_api_key_here
CLOD_BASE_URL=https://api.clod.io/v1
CLOD_MODEL=GPT OSS 120B


# ── GitHub Integration ────────────────────────────────────────
# Required for Phase 5 sandbox (opening real PRs for Greptile review).
# Also improves Phase 1 repo search (avoids rate limits on GitHub Search).
# Create a classic token at: https://github.com/settings/tokens
# Required scopes: repo, read:org
GITHUB_TOKEN=your_github_classic_token_here

# The sandbox repository where generated code is committed as PRs.
# Must be a repo you own and have write access to.
# Default: sebastianZzzz/AegisHarness-Demo
# SANDBOX_REPO=your_github_username/your_sandbox_repo


# ── Greptile (Phase 2 & Phase 5 code review) ─────────────────
# Greptile indexes repos and reviews generated code against them.
# Get your key at: https://app.greptile.com/settings/api
GREPTILE_API_KEY=your_greptile_api_key_here


# ── Nia (optional alternative repo search) ───────────────────
# Used when search_provider=nia is selected in the UI.
# Get your key at: https://trynia.ai
NIA_API_KEY=your_nia_api_key_here


# ── Runtime Controls ──────────────────────────────────────────
# Maximum sandbox repair iterations before marking a task as FAILED.
AEGIS_MAX_ITERATIONS=3

# Minimum confidence score (0-100) before human approval is required.
AEGIS_CONFIDENCE_THRESHOLD=70
