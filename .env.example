# Copy this file to .env.local for frontend/dev usage or .env for backend usage.
# Do not commit real secrets.


# Gemini is the primary AI provider. If GEMINI_API_KEY is set, AegisHarness uses it before Clod.
GEMINI_API_KEY=""
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta
GEMINI_MODEL=gemini-2.5-flash-lite

# Clod.io fallback. Used only when GEMINI_API_KEY is absent.
CLOD_API_KEY=""
CLOD_BASE_URL=https://api.clod.io/v1
CLOD_MODEL=GPT OSS 120B


# Optional runtime controls.
AEGIS_MAX_ITERATIONS=3
AEGIS_CONFIDENCE_THRESHOLD=70
