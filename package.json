{
  "name": "aegis-harness",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "build": "tsc -b && vite build",
    "preview": "vite preview --host 0.0.0.0",
    "lint": "eslint .",
    "backend": "export PYTHONPATH=$PYTHONPATH:$(pwd)/backend && conda run -n aegis-harness uvicorn app.main:app --host 0.0.0.0 --port 8000 --reload",
    "test:python": "conda run -n aegis-harness python -m pytest backend/tests/"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^5.0.4",
    "vite": "^7.1.9",
    "typescript": "^5.9.3",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "lucide-react": "^0.545.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.36.0",
    "@types/react": "^19.1.16",
    "@types/react-dom": "^19.1.9",
    "typescript-eslint": "^8.45.0",
    "eslint": "^9.36.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.22",
    "globals": "^16.4.0"
  }
}
